<launch>
  <node pkg="cure_planner" type="frontier_assigner_node" name="frontier_assigner" output="screen">
    <param name="num_robots" value="4"/>
    <param name="frontier_robot_min_dist" value="1.0"/>
    <param name="min_dist" value="4.5"/>
    <!-- <param name="min_dist" value="4.0"/> -->
    <param name="max_dist" value="9.0"/>
    <param name="reach_radius" value="1.6"/>
    <param name="max_heading_angle_deg" value="100.0"/>
    <param name="target_marker_scale" value="0.5"/>
    <param name="ref_inertia_alpha" value="0.5"/>
    <param name="ref_inertia_max_step" value="0.5"/>
    <param name="ref_inertia_min_step" value="0.5"/>

    <param name="block_merge_eps" value="2.0"/>
    <param name="anchor_pause_K" value="3"/>

    <param name="rate_hz" value="10.0"/>
    <param name="global_frame" value="map"/>

    <param name="inter_robot_threshold" value="1.5"/>
    <!-- <param name="inter_robot_threshold" value="1.0"/> -->
    <param name="cluster_window" value="10.0"/>
    <param name="cluster_radius" value="3.0"/>
    <param name="frontier_merge_eps" value="0.35"/>
    <param name="goal_dedup_eps" value="0.45"/>
    <param name="stuck_retry_merge_eps" value="0.45"/>
    <param name="perm_block_merge_eps" value="0.3"/>
    <param name="jump_guard_dist_th" value="20.0"/>
    <param name="jump_guard_yaw_th" value="90.0"/>
    <param name="jump_guard_max_ct" value="3"/>
    <param name="stuck_move_eps" value="0.01"/>
    <param name="stuck_prog_eps" value="0.01"/>
    <param name="stuck_cycles" value="100"/>
    <param name="robot_forbidden_merge_eps" value="0.45"/>
    <param name="anchor_hist_drop_eps" value="2.0"/>
    <param name="anchor_hist_merge_eps" value="0.3"/>
    <param name="anchor_hist_max_size" value="40000"/>
  </node>
</launch>
