<launch>
  <param name="use_sim_time" value="true"/>

  <node pkg="cure_planner"
        type="traj_visualizer.py"
        name="traj_visualizer"
        output="screen">
    <param name="topic_name" value="/record_traj_topic"/>
    <param name="frame_id" value="map"/>
    <param name="num_robot" value="4"/>
    <param name="line_width" value="0.06"/>
    <param name="point_size" value="0.18"/>
    <param name="arrow_scale" value="0.35"/>
    <param name="min_dist_append" value="0.02"/>
    <param name="show_heading" value="true"/>
    <param name="z_offset" value="0.05"/>
  </node>

  <node pkg="rviz"
        type="rviz"
        name="rviz"
        args="-d $(find cure_planner)/launch/three_robot.rviz"/>
</launch>